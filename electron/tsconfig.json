{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "jsx": "react-jsx",
    "lib": ["ES2022", "DOM"],
    "types": ["node", "react", "react-dom"]
  },
  "include": ["./**/*.ts", "./**/*.tsx", "./renderer/**/*.d.ts"],
  "exclude": ["./dist", "./renderer/dist"]
}
